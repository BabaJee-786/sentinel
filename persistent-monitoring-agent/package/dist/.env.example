# Sentinel Persistent Agent Configuration
#
# Copy this file to .env before installing the agent.

# Backend API endpoint
SENTINEL_API_BASE=https://your-sentinel-server.com/backend/api/index.php

# API key used by the agent
SENTINEL_API_KEY=your-secure-api-key-change-this

# Admin key if your backend requires privileged actions
SENTINEL_ADMIN_KEY=your-admin-key-change-this

# Redirect IP used for blocked domains
SENTINEL_BLOCK_REDIRECT_IP=127.0.0.2
